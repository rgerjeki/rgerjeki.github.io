    <item>
      <title>Home Affordability Calculator</title>
      <link>http://localhost:1313/tools/home-affordability/</link>
      <pubDate>Mon, 01 Jan 2024 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/tools/home-affordability/</guid>
      <description>&lt;section class=&#34;container tools-section&#34;&gt;&#xA;  &lt;div class=&#34;tool-card&#34;&gt;&#xA;    &lt;div class=&#34;tool-copy&#34;&gt;&#xA;      &lt;h2&gt;Plan your budget&lt;/h2&gt;&#xA;      &lt;p&gt;Estimate what you can comfortably spend on a home using your income, debts, and a realistic monthly payment target. Adjust the inputs to explore different down payments and rates.&lt;/p&gt;&#xA;      &lt;p&gt;We size your budget using a debt-to-income (DTI) limit and include property taxes, insurance, and optional HOA dues. Use it to sanity-check listings before you talk to a lender.&lt;/p&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;form id=&#34;affordability-form&#34; class=&#34;affordability-form&#34;&gt;&#xA;      &lt;div class=&#34;input-grid&#34;&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;Annual gross income&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;annualIncome&#34; value=&#34;98000&#34; min=&#34;0&#34; step=&#34;1000&#34; required&gt;&#xA;        &lt;/label&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;Monthly debt payments&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;monthlyDebt&#34; value=&#34;800&#34; min=&#34;0&#34; step=&#34;50&#34; required&gt;&#xA;        &lt;/label&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;Down payment (cash ready)&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;downPayment&#34; value=&#34;5000&#34; min=&#34;0&#34; step=&#34;500&#34; required&gt;&#xA;        &lt;/label&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;Interest rate (APR)&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;interestRate&#34; value=&#34;6.5&#34; min=&#34;0&#34; max=&#34;15&#34; step=&#34;0.05&#34; required&gt;&#xA;        &lt;/label&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;Loan term (years)&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;loanTerm&#34; value=&#34;30&#34; min=&#34;5&#34; max=&#34;40&#34; step=&#34;1&#34; required&gt;&#xA;        &lt;/label&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;Max debt-to-income (DTI) %&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;dtiLimit&#34; value=&#34;36&#34; min=&#34;20&#34; max=&#34;50&#34; step=&#34;1&#34; required&gt;&#xA;        &lt;/label&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;Property tax rate (% of price, annual)&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;taxRate&#34; value=&#34;1.2&#34; min=&#34;0&#34; max=&#34;5&#34; step=&#34;0.05&#34; required&gt;&#xA;        &lt;/label&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;Homeowner&#39;s insurance (monthly)&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;insurance&#34; value=&#34;150&#34; min=&#34;0&#34; step=&#34;10&#34; required&gt;&#xA;        &lt;/label&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;HOA dues (monthly, optional)&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;hoa&#34; value=&#34;0&#34; min=&#34;0&#34; step=&#34;10&#34;&gt;&#xA;        &lt;/label&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;Extra principal (monthly, optional)&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;extraMonthly&#34; value=&#34;0&#34; min=&#34;0&#34; step=&#34;50&#34;&gt;&#xA;        &lt;/label&gt;&#xA;        &lt;label&gt;&#xA;          &lt;span&gt;Extra principal each year (optional)&lt;/span&gt;&#xA;          &lt;input type=&#34;number&#34; name=&#34;extraAnnual&#34; value=&#34;0&#34; min=&#34;0&#34; step=&#34;250&#34;&gt;&#xA;        &lt;/label&gt;&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;div class=&#34;tool-actions&#34;&gt;&#xA;        &lt;button type=&#34;submit&#34;&gt;Calculate affordability&lt;/button&gt;&#xA;        &lt;p class=&#34;footnote&#34;&gt;Educational estimate only—actual approval depends on credit, reserves, and property-specific costs.&lt;/p&gt;</description>
