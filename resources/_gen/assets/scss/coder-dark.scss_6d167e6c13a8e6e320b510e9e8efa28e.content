      color: #8b949e; }
    body.colorscheme-auto .chroma .gs {
      font-weight: bold; }
    body.colorscheme-auto .chroma .gu {
      color: #79c0ff; }
    body.colorscheme-auto .chroma .gt {
      color: #ff7b72; }
    body.colorscheme-auto .chroma .gl {
      text-decoration: underline; }
    body.colorscheme-auto .chroma .w {
      color: var(--fg-muted); } }

