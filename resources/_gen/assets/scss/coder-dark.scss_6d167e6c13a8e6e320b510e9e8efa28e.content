body.colorscheme-dark .notice .notice-title {
  border-bottom: 1px solid #15181c; }

@media (prefers-color-scheme: dark) {
  body.colorscheme-auto .notice .notice-title {
    border-bottom: 1px solid #15181c; } }

body.colorscheme-dark .tabs label.tab-label {
  background-color: #232830;
  border-color: #2a3039; }

body.colorscheme-dark .tabs input.tab-input:checked + label.tab-label {
  background-color: #15181c; }

body.colorscheme-dark .tabs .tab-content {
  background-color: #15181c;
  border-color: #2a3039; }

@media (prefers-color-scheme: dark) {
  body.colorscheme-auto .tabs label.tab-label {
    background-color: #232830;
    border-color: #2a3039; }
  body.colorscheme-auto .tabs input.tab-input:checked + label.tab-label {
    background-color: #15181c; }
  body.colorscheme-auto .tabs .tab-content {
    background-color: #15181c;
    border-color: #2a3039; } }

body.colorscheme-dark .taxonomy-element {
  background-color: #232830; }
  body.colorscheme-dark .taxonomy-element a {
    color: #e6e7e4; }
  body.colorscheme-dark .taxonomy-element a:active {
    color: #e6e7e4; }

@media (prefers-color-scheme: dark) {
  body.colorscheme-auto .taxonomy-element {
    background-color: #232830; }
    body.colorscheme-auto .taxonomy-element a {
      color: #e6e7e4; }
    body.colorscheme-auto .taxonomy-element a:active {
      color: #e6e7e4; } }

:root.colorscheme-dark,
html.colorscheme-dark,
body.colorscheme-dark {
  --chart-principal: #2a9ed1;
  --chart-interest: #d86b8a; }

.amortization-card {
  background: #232830; }
  .amortization-card .amortization-legend .swatch.principal {
    background: #2a9ed1; }
  .amortization-card .amortization-legend .swatch.interest {
    background: #d86b8a; }
  .amortization-card .chart-frame {
    border-color: #2a3039;
    background: #15181c; }
    .amortization-card .chart-frame .chart-tooltip {
      background: rgba(0, 0, 0, 0.9);
      color: #e6e7e4; }
  .amortization-card .amortization-summary .label {
    color: #f2f3f0; }
  .amortization-card .amortization-summary .value {
    color: #e6e7e4; }
  .amortization-card .amortization-table table th,
  .amortization-card .amortization-table table td {
    border-bottom: 1px solid #2a3039; }
  .amortization-card .amortization-table table thead {
    background: #232830; }

body.colorscheme-dark .tools-section .eyebrow {
  color: #2dd4bf; }

body.colorscheme-dark .tool-card {
  background: #232830; }
  body.colorscheme-dark .tool-card label span {
    color: #f2f3f0; }
  body.colorscheme-dark .tool-card label input {
    background: #15181c;
    color: #e6e7e4;
    border-color: #2a3039; }
    body.colorscheme-dark .tool-card label input:focus {
      outline-color: #2dd4bf;
      border-color: #2dd4bf; }

body.colorscheme-dark .tool-actions button {
  background: #2dd4bf; }

body.colorscheme-dark .tool-actions .footnote {
  color: #f2f3f0; }

body.colorscheme-dark .tools-results {
  background: #15181c;
  border-color: #2a3039; }

body.colorscheme-dark .result-grid .result {
  background: #232830; }
  body.colorscheme-dark .result-grid .result .label {
    color: #f2f3f0; }
  body.colorscheme-dark .result-grid .result .value {
    color: #e6e7e4; }

body.colorscheme-dark .result-breakdown ul li {
  background: #232830; }

@media (prefers-color-scheme: dark) {
  body.colorscheme-auto .tools-section .eyebrow {
    color: #2dd4bf; }
  body.colorscheme-auto .tool-card {
